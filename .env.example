# Public URL of your site
# Keep data/articles.local.json in repo as SEO fallback snapshot
SITE_URL=https://whalewzrd.com

# JSONBin read endpoint for latest articles
JSONBIN_URL=https://api.jsonbin.io/v3/b/69de47b136566621a8b15081/latest

# Optional for private bins (build scripts)
JSONBIN_ACCESS_KEY=
JSONBIN_MASTER_KEY=

# Optional strict mode for CI (fail build if JSONBin + fallback unavailable)
STRICT_ARTICLES_FETCH=false
ARTICLES_FETCH_RETRIES=3
ARTICLES_FETCH_TIMEOUT_MS=10000

# Optional browser-side read key (public in frontend bundle)
VITE_JSONBIN_ACCESS_KEY=
