# Public URL of your site
# Keep data/articles.local.json in repo as SEO fallback snapshot
SITE_URL=https://whalewzrd.com

# JSONBin read endpoint for latest articles
JSONBIN_URL=https://api.jsonbin.io/v3/b/69de47b136566621a8b15081/latest

# Optional for private bins (build scripts)
JSONBIN_ACCESS_KEY=
JSONBIN_MASTER_KEY=

# Optional strict mode for CI (fail build if JSONBin + fallback unavailable)
STRICT_ARTICLES_FETCH=false
ARTICLES_FETCH_RETRIES=3
ARTICLES_FETCH_TIMEOUT_MS=10000

# Optional browser-side read key (public in frontend bundle)
VITE_JSONBIN_ACCESS_KEY=

# Meta Conversions API (server-side)
# META_CAPI_ACCESS_TOKEN is secret and should be set in Cloudflare, not committed.
VITE_META_PIXEL_ID=926332213606723
META_CAPI_API_VERSION=v25.0
META_CAPI_TEST_CODE=
META_CAPI_DEBUG_SECRET=
# Optional Meta Limited Data Use / data processing options.
# Example for automatic Meta geolocation: META_CAPI_DATA_PROCESSING_OPTIONS=LDU, COUNTRY=0, STATE=0.
META_CAPI_DATA_PROCESSING_OPTIONS=
META_CAPI_DATA_PROCESSING_OPTIONS_COUNTRY=
META_CAPI_DATA_PROCESSING_OPTIONS_STATE=
